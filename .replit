odules = ["python-3.11"]

# Force Streamlit to run on the standard web port 3000
run = "streamlit run scripts/src/app.py --server.port 3000 --server.address 0.0.0.0"
modules = ["python-3.11", "nodejs-20"]

[nix]
packages = ["csound", "twelf"]
channel = "stable-25_05"

[agent]
expertMode = true

# This block is CRITICAL for the Replit web view to find your app
[web]
port = 3000

[[ports]]
localPort = 3000
externalPort = 80

[[ports]]
localPort = 8000
externalPort = 8000

[[ports]]
localPort = 23110
externalPort = 3000

[deployment]
deploymentTarget = "cloudrun"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "streamlit run scripts/src/app.py --server.port 8000 --server.address 0.0.0.0"
waitForPort = 8000
