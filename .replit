odules = ["python-3.11"]

# Force Streamlit to run on the standard web port 3000
run = "streamlit run scripts/src/app.py --server.port 3000 --server.address 0.0.0.0"
modules = ["python-3.11", "nodejs-20"]

[nix]
packages = ["csound", "twelf"]
channel = "stable-25_05"

[agent]
expertMode = true

# This block is CRITICAL for the Replit web view to find your app
[web]
port = 3000

[[ports]]
localPort = 3000
externalPort = 80

[deployment]
deploymentTarget = "cloudrun"
